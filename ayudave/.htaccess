DirectoryIndex index.html

AddType application/manifest+json .webmanifest
AddType application/javascript .js
AddType application/json .json
AddType application/xml .xml
AddType image/svg+xml .svg

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  <FilesMatch "\.(js|css|svg|webmanifest)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^(index|admin|sitemap|robots|sources|openapi|llms|ayuda-terremoto-venezuela|como-reportar-ayuda-venezuela|directorio-ayuda-venezuela|datos-abiertos-ayudave)\.(html|xml|txt|json)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>
  <Files "sw.js">
    Header set Cache-Control "no-cache"
  </Files>
</IfModule>

<Files "config.php">
  Require all denied
</Files>
